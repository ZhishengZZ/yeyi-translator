{
  "manifest_version": 3,
  "name": "雅译 · AI 网页翻译",
  "description": "填写自己的 OpenAI 兼容模型 API Key 后，即可进行网页翻译、上下文精翻和搜索词翻译。",
  "version": "0.4.0",
  "icons": {
    "16": "src/assets/yeyi-icon-16.png",
    "32": "src/assets/yeyi-icon-32.png",
    "48": "src/assets/yeyi-icon-48.png",
    "128": "src/assets/yeyi-icon-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "topSites", "favicon"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "雅译",
    "default_icon": {
      "16": "src/assets/yeyi-icon-16.png",
      "32": "src/assets/yeyi-icon-32.png",
      "48": "src/assets/yeyi-icon-48.png",
      "128": "src/assets/yeyi-icon-128.png"
    },
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "开始或恢复网页翻译"
    }
  }
}
